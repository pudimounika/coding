import java.util.*;

class Solution {
    public static void bubbleSort(int[] arr,int m) {

        if(m == 1) return;

        for(int i=0;i<m-1;i++){
            if(arr[i] > arr[i+1]){
                int swap = arr[i];
                arr[i] = arr[i+1];
                arr[i+1] = swap;
            }
        }

        bubbleSort(arr,m-1);
    }
}

