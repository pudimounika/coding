class Solution {
    public void bubbleSort(int[] arr) {
        // code here
        for(int i=0;i<arr.length;i++){
            for(int j=0;j<arr.length-i-1;j++){
                if(arr[j] > arr[j+1]){
                   int swap = arr[j];
                   arr[j] = arr[j+1];
                   arr[j+1] = swap;
                }
            }
        }
    }
}
