		if(left > right) return -1;
		int mid = (left+right)/2;
		if(arr[mid] == k) return mid;
		if(arr[mid] > k){
			return binarySearch(arr,left,mid-1,k);
		}
		return binarySearch(arr,mid+1,right,k);
	}
