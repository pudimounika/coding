class Solution {
    public int binarysearch(int[] arr, int k) {
        int left = 0,right = arr.length-1,ans = -1;
        while(left<=right){
            int mid = (left+right)/2;
            if(arr[mid] == k){
                ans = mid;
                right = mid-1;
            }
            else if(arr[mid] > k){
                right = mid-1;
            }
            else{
                left = mid+1;
            }
        }
        return ans;
    }
}
